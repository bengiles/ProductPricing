@page "/products"
@using ProductPricing.Helpers
@using ProductPricing.Models
@using ProductPricing.Components.Shared
@rendermode InteractiveServer
@inject IApiHelper Api
@inherits ProductsBase

<PageTitle>Products</PageTitle>

<h1>Product Pricing</h1>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = string.Empty"></button>
    </div>
}

<ProductList Items="_products" TItem="Product">
    <HeaderTemplate>
        <th>Name</th>
        <th>Price</th>
        <th>Last Updated</th>
        <th>Discount (%)</th>
        <th>New Price</th>
        <th>Actions</th>
    </HeaderTemplate>
    <RowTemplate Context="product">
        <td>@product.Name</td>
        <td>
            @if (product.DiscountedPrice.HasValue)
            {
                <span class="text-decoration-line-through text-muted">@product.Price.ToString(DisplayAsCurrency)</span>
                <br />
                <span class="text-success fw-bold">@product.DiscountedPrice.Value.ToString(DisplayAsCurrency)</span>
                <span class="badge bg-warning text-dark">-@product.DiscountPercentage%</span>
            }
            else
            {
                @product.Price.ToString(DisplayAsCurrency)
            }
        </td>
        <td>@product.LastUpdated.ToString(DisplayAsDate)</td>
        <ProductDetail Product="product"
                       DiscountInput="_discountInputs[product.Id]"
                       DiscountInputChanged="val => _discountInputs[product.Id] = val"
                       PriceInput="_priceInputs[product.Id]"
                       PriceInputChanged="val => _priceInputs[product.Id] = val"
                       OnApplyDiscount="() => ApplyDiscount(product.Id)"
                       OnClearDiscount="() => ClearDiscount(product.Id)"
                       OnUpdatePrice="() => UpdatePrice(product.Id)"
                       OnViewHistory="() => ViewHistory(product.Id)" />
    </RowTemplate>
</ProductList>

<PriceHistory Product="_selectedHistory" OnClose="() => _selectedHistory = null" />