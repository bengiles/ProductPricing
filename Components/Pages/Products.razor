@page "/products"
@using ProductPricing.Helpers
@rendermode InteractiveServer
@inject IApiHelper Api
@inherits ProductsBase

<PageTitle>Products</PageTitle>

<h1>Product Pricing</h1>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = string.Empty"></button>
    </div>
}

@if (_products is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Last Updated</th>
                <th>Discount (%)</th>
                <th>New Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in _products)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>
                        @if (product.DiscountedPrice.HasValue)
                        {
                            <span class="text-decoration-line-through text-muted">@product.Price.ToString(DisplayAsCurrency)</span>
                            <br />
                            <span class="text-success fw-bold">@product.DiscountedPrice.Value.ToString(DisplayAsCurrency)</span>
                            <span class="badge bg-warning text-dark">-@product.DiscountPercentage%</span>
                        }
                        else
                        {
                            @product.Price.ToString(DisplayAsCurrency)
                        }
                    </td>
                    <td>@product.LastUpdated.ToString(DisplayAsDate)</td>
                    <td style="width:140px">
                        <input type="number" class="form-control form-control-sm" min="0" max="100"
                               @bind="_discountInputs[product.Id]" placeholder="0-100" />
                    </td>
                    <td style="width:140px">
                        <input type="number" class="form-control form-control-sm" min="0.01" step="0.01"
                               @bind="_priceInputs[product.Id]" placeholder="New price" />
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => ApplyDiscount(product.Id)">
                            Apply Discount
                        </button>
                        @if (product.DiscountedPrice.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => ClearDiscount(product.Id)">
                                Clear Discount
                            </button>
                        }
                        <button class="btn btn-sm btn-primary me-1" @onclick="() => UpdatePrice(product.Id)">
                            Update Price
                        </button>
                        <button class="btn btn-sm btn-info" @onclick="() => ViewHistory(product.Id)">
                            View History
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_selectedHistory is not null)
{
    <div class="card mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Price History — @_selectedHistory.Name</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _selectedHistory = null">Close</button>
        </div>
        <div class="card-body">
            @if (_selectedHistory.PriceHistory.Count == 0)
            {
                <p>No price history available.</p>
            }
            else
            {
                <table class="table table-sm">
                    <thead>
                        <tr><th>Price</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _selectedHistory.PriceHistory)
                        {
                            <tr>
                                <td>@entry.Price.ToString(DisplayAsCurrency)</td>
                                <td>@entry.Date</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}