@using ProductPricing.Models

@if (Product is not null)
{
    <div class="card mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Price History — @Product.Name</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="OnClose">Close</button>
        </div>
        <div class="card-body">
            @if (Product.PriceHistory.Count == 0)
            {
                <p>No price history available.</p>
            }
            else
            {
                <table class="table table-sm">
                    <thead>
                        <tr><th>Price</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Product.PriceHistory)
                        {
                            <tr>
                                <td>@entry.Price.ToString("C")</td>
                                <td>@entry.Date</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Product? Product { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}